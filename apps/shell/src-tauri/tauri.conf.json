{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Casual Office",
  "version": "0.0.0",
  "identifier": "live.schnsrw.casualoffice",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5170",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Casual Office",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Casual Office — local Word & Excel editor",
    "longDescription": "Casual Office is a local-only desktop editor for Word (.docx) and Excel (.xlsx, .ods, .csv, .tsv) documents. Files never leave your machine.",
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["docx"],
        "name": "Word Document",
        "description": "Microsoft Word document",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "role": "Editor"
      },
      {
        "ext": ["xlsx", "xlsm"],
        "name": "Excel Workbook",
        "description": "Microsoft Excel workbook",
        "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "role": "Editor"
      },
      {
        "ext": ["ods"],
        "name": "OpenDocument Spreadsheet",
        "description": "OpenDocument spreadsheet",
        "mimeType": "application/vnd.oasis.opendocument.spreadsheet",
        "role": "Editor"
      },
      {
        "ext": ["csv"],
        "name": "Comma-separated values",
        "description": "Comma-separated values",
        "mimeType": "text/csv",
        "role": "Editor"
      },
      {
        "ext": ["tsv", "tab"],
        "name": "Tab-separated values",
        "description": "Tab-separated values",
        "mimeType": "text/tab-separated-values",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "postInstallScript": "scripts/postinst.sh"
      }
    }
  }
}
